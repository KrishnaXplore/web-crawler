{
  "name": "@crawler/renderer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@crawler/config": "workspace:*",
    "@crawler/core": "workspace:*",
    "@crawler/db": "workspace:*",
    "@crawler/logger": "workspace:^",
    "@crawler/metrics": "workspace:*",
    "@crawler/queue": "workspace:*",
    "@crawler/shared": "workspace:*",
    "@crawler/storage": "workspace:*",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2",
    "playwright": "^1.49.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
