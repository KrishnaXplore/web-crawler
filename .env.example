# Copy to .env and adjust as needed. packages/config validates these at boot.
REDIS_URL=redis://localhost:6380
MONGO_URL=mongodb://localhost:27018/crawler
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=crawler-blobs
WORKER_CONCURRENCY=4
CRAWL_DELAY_MS=200
CRAWL_USER_AGENT=web-intelligence-platform-crawler/0.1 (+https://example.com/bot)
# Optional: HMAC secret for signing webhook deliveries (X-Crawler-Signature).
# WEBHOOK_SECRET=change-me
# Optional: Gemini API key for real Tier 4 rule generation. Unset ⇒ mockLlmSocket.
# Free key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-3.1-flash-lite
# Renderer runs headless by default (correct for a backend service). Set to
# false only for local debugging when you want to watch the browser.
# RENDER_HEADLESS=true
